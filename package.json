{
  "name": "@dolphin-molt/reado",
  "version": "0.1.0",
  "description": "信息聚合 CLI 工具 - 一站式获取 AI 资讯、科技新闻、社区热点",
  "type": "module",
  "bin": {
    "reado": "./dist/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "rss",
    "news",
    "ai",
    "aggregator",
    "hacker-news",
    "reddit",
    "twitter",
    "github",
    "bilibili",
    "zhihu"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/checkbox": "^5.1.2",
    "@inquirer/select": "^5.1.2",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "fast-xml-parser": "^4.4.1",
    "ofetch": "^1.4.1",
    "ora": "^8.1.1",
    "p-limit": "^6.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
